verify-razorpay-only.sh
verify-setup.sh

# -----------------------------------------------------------------------------
# One-off CLI notes / command scratch files
# -----------------------------------------------------------------------------
cmdi.txt

# -----------------------------------------------------------------------------
# Example / Reference Files (not part of the deployed app)
# -----------------------------------------------------------------------------
examples/

# -----------------------------------------------------------------------------
# Memory Folder (AI/agent memory, not app code)
# -----------------------------------------------------------------------------
memory/

# -----------------------------------------------------------------------------
# .emergent Folder (AI agent config, not needed in repo)
# -----------------------------------------------------------------------------
.emergent/

# -----------------------------------------------------------------------------
# .gitconfig (local git user config — should not be in project repo)
# -----------------------------------------------------------------------------
.gitconfig

# -----------------------------------------------------------------------------
# Misc Dev Artifacts
# -----------------------------------------------------------------------------
chainlit.md
.chainlit/
.ipynb_checkpoints/
.ac
.data/

