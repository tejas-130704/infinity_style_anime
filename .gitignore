# =============================================================================
# .gitignore — Next.js Full-Stack Project
# Project: Infinity Style Anime (Mugen Drip)
# Deployment: Vercel (via GitHub push)
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Next.js Build Output
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/

# Generated by Next.js — do not commit
next-env.d.ts
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & Secrets  ← NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example        # Allow the example/template file to be committed
*.env
*token.json
*credentials.json
rzp-key.csv          # Razorpay API key file — sensitive

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# -----------------------------------------------------------------------------
# Cache & Temp
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.vite/
.turbo/
.swc/
*.swp
*.swo

# -----------------------------------------------------------------------------
# OS / System Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
/coverage
test_reports/
test_result.md
tests/
pytest/

# -----------------------------------------------------------------------------
# Uploaded / User-Generated Files (runtime, not source)
# -----------------------------------------------------------------------------
uploaded_app/

# -----------------------------------------------------------------------------
# Archives & Large Binaries
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.pack
*.deb
*.dylib
*.exe
*.dll
*.so
*.node

# -----------------------------------------------------------------------------
# Python (if any scripts are present)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/

# -----------------------------------------------------------------------------
# Deployment Platforms
# -----------------------------------------------------------------------------
.vercel
.netlify

# -----------------------------------------------------------------------------
# Dev-Only Documentation (not needed for deployment)
# These are local dev notes, fix guides, and setup docs — not app code.
# -----------------------------------------------------------------------------
DATABASE_SETUP_GUIDE.md
IMPLEMENTATION_PROGRESS.md
QUICK_FIX_GUIDE.md
RUN_THIS_SQL_NOW.md
SETUP_AND_AUTH_GUIDE.md
